# PAM common-password
# Managed by Ansible role linux_authselect_ubuntu
# CIS Ubuntu Linux Benchmark — 5.4.1 / 5.4.3

password    requisite     pam_pwquality.so retry=3
password    required      pam_pwhistory.so remember={{ linux_authselect_remember }} use_authtok
password    [success=1 default=ignore]  pam_unix.so obscure yescrypt sha512 shadow use_authtok
password    requisite     pam_deny.so
password    required      pam_permit.so
