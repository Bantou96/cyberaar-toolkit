# Generated: {{ ansible_date_time.iso8601 }}
# CIS Ubuntu Linux Benchmark — 3.1.x

# IPv4 forwarding (set to 1 only for routers/VPN gateways)
net.ipv4.ip_forward = {{ 1 if linux_ip_forwarding_enable_ipv4 | bool else 0 }}

# IPv6 forwarding
net.ipv6.conf.all.forwarding = {{ 1 if linux_ip_forwarding_enable_ipv6 | bool else 0 }}
