## CIS Ubuntu Linux Benchmark - auditd Configuration
## Managed by Ansible role: linux_auditing_ubuntu
## Last applied: {{ ansible_date_time.iso8601 }}

local_events = yes
write_logs = yes
log_file = /var/log/audit/audit.log
log_group = root
priority_boost = 4
disp_qos = lossy
flush = {{ linux_auditd_flush }}
freq = 50
max_log_file = {{ linux_auditd_max_log_file }}
max_log_file_action = {{ linux_auditd_max_log_file_action }}
space_left = 75
space_left_action = {{ linux_auditd_space_left_action }}
verify_email = yes
action_mail_acct = root
admin_space_left = 50
admin_space_left_action = {{ linux_auditd_admin_space_left_action }}
disk_full_action = {{ linux_auditd_disk_full_action }}
disk_error_action = syslog
