# CIS / STIG hardened remote forwarding for audit + system logs
# Managed by Ansible role: linux_auditing_ubuntu
# Generated: {{ ansible_date_time.iso8601 }}

{% if linux_rsyslog_queue_disk | bool %}
# Modern RainerScript action with disk queue
action(type="omfwd"
  target="{{ linux_rsyslog_remote_host }}"
  port="{{ linux_rsyslog_remote_port }}"
  protocol="{{ linux_rsyslog_remote_protocol }}"
  action.resumeRetryCount="-1"
  queue.type="LinkedList"
  queue.filename="audit_fwd_queue"
  queue.maxDiskSpace="1g"
  queue.saveOnShutdown="on"
{% if linux_rsyslog_remote_use_tls | bool %}
  StreamDriver="gtls"
  StreamDriverMode="1"
  StreamDriverAuthMode="x509/name"
  StreamDriverCAFile="{{ linux_rsyslog_remote_tls_ca_cert }}"
{% if linux_rsyslog_remote_tls_cert | length > 0 %}
  StreamDriverCertFile="{{ linux_rsyslog_remote_tls_cert }}"
  StreamDriverKeyFile="{{ linux_rsyslog_remote_tls_key }}"
{% endif %}
{% endif %}
)
{% else %}
*.* action(type="omfwd" target="{{ linux_rsyslog_remote_host }}" port="{{ linux_rsyslog_remote_port }}" protocol="{{ linux_rsyslog_remote_protocol }}")
{% endif %}
