## CIS Red Hat Enterprise Linux 9 Benchmark v2.0.0 + extended hardening
## Managed by Ansible role: linux_auditing_rhel9
## Managed by Ansible — do not edit manually

-D
-b 8192

## ──────────────────────────────────────────────
##  Identity & authentication files
## ──────────────────────────────────────────────
{% if linux_audit_rules_identity | bool %}
-w /etc/passwd -p wa -k identity
-w /etc/group -p wa -k identity
-w /etc/shadow -p wa -k identity
-w /etc/gshadow -p wa -k identity
-w /etc/opasswd -p wa -k identity
-w /etc/security/opasswd -p wa -k identity
-w /etc/security/passwd -p wa -k identity
-w /etc/nsswitch.conf -p wa -k identity
-w /etc/pam.d/ -p wa -k pam
-w /etc/security/pwquality.conf -p wa -k identity
-w /etc/security/faillock.conf -p wa -k identity
{% endif %}

## ──────────────────────────────────────────────
##  Privileged / setuid-like commands
## ──────────────────────────────────────────────
{% if linux_audit_rules_privileged | bool %}
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/at -F perm=x -F auid>=1000 -F auid!=unset -k privileged
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/chage -F perm=x -F auid>=1000 -F auid!=unset -k privileged
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/chfn -F perm=x -F auid>=1000 -F auid!=unset -k privileged
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/chsh -F perm=x -F auid>=1000 -F auid!=unset -k privileged
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/crontab -F perm=x -F auid>=1000 -F auid!=unset -k privileged
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/gpasswd -F perm=x -F auid>=1000 -F auid!=unset -k privileged
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/mount -F perm=x -F auid>=1000 -F auid!=unset -k privileged
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/newgrp -F perm=x -F auid>=1000 -F auid!=unset -k privileged
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/passwd -F perm=x -F auid>=1000 -F auid!=unset -k privileged
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/pkexec -F perm=x -F auid>=1000 -F auid!=unset -k privileged
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/su -F perm=x -F auid>=1000 -F auid!=unset -k privileged
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/sudo -F perm=x -F auid>=1000 -F auid!=unset -k privileged
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/sudoedit -F perm=x -F auid>=1000 -F auid!=unset -k privileged
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/umount -F perm=x -F auid>=1000 -F auid!=unset -k privileged
-a always,exit -F arch=b64 -S execve -F path=/usr/sbin/usermod -F perm=x -F auid>=1000 -F auid!=unset -k privileged
{% endif %}

## ──────────────────────────────────────────────
##  Permission / ownership changes
## ──────────────────────────────────────────────
{% if linux_audit_rules_perm_mod | bool %}
-a always,exit -F arch=b64 -S chmod,fchmod,fchmodat -F auid>=1000 -F auid!=unset -k perm_mod
-a always,exit -F arch=b64 -S chown,fchown,fchownat,lchown -F auid>=1000 -F auid!=unset -k perm_mod
{% endif %}

## ──────────────────────────────────────────────
##  Mount / unmount events
## ──────────────────────────────────────────────
{% if linux_audit_rules_mounts | bool %}
-a always,exit -F arch=b64 -S mount -F auid>=1000 -F auid!=unset -k mounts
-a always,exit -F arch=b64 -S umount,umount2 -F auid>=1000 -F auid!=unset -k mounts
{% endif %}

## ──────────────────────────────────────────────
##  Configuration & scheduled tasks changes
## ──────────────────────────────────────────────
{% if linux_audit_rules_actions | bool %}
-w /etc/sudoers -p wa -k actions
-w /etc/sudoers.d/ -p wa -k actions
-w /etc/crontab -p wa -k cron
-w /etc/cron.d/ -p wa -k cron
-w /etc/cron.daily/ -p wa -k cron
-w /etc/cron.hourly/ -p wa -k cron
-w /etc/cron.weekly/ -p wa -k cron
-w /etc/cron.monthly/ -p wa -k cron
-w /etc/anacrontab -p wa -k cron
-w /etc/at.deny -p wa -k at
-w /etc/at.allow -p wa -k at
-w /etc/systemd/ -p wa -k systemd
{% endif %}

## ──────────────────────────────────────────────
##  File deletion / rename (can be noisy – disabled by default in many profiles)
## ──────────────────────────────────────────────
{% if linux_audit_rules_delete | bool %}
-a always,exit -F arch=b64 -S unlink,unlinkat,rename,renameat -F auid>=1000 -F auid!=unset -k delete
{% endif %}

## ──────────────────────────────────────────────
##  SELinux / security context changes
## ──────────────────────────────────────────────
{% if linux_audit_rules_selinux | bool %}
-a always,exit -F arch=b64 -S setenforce -F auid>=1000 -F auid!=unset -k selinux
-w /etc/selinux/ -p wa -k selinux
-w /etc/sestatus.conf -p wa -k selinux
-a always,exit -F arch=b64 -S chcon -F auid>=1000 -F auid!=unset -k selinux
-a always,exit -F arch=b64 -S semanage -F auid>=1000 -F auid!=unset -k selinux
-a always,exit -F arch=b64 -S restorecon -F auid>=1000 -F auid!=unset -k selinux
{% endif %}

## ──────────────────────────────────────────────
##  Kernel module load/unload (very useful for rootkit detection)
## ──────────────────────────────────────────────
{% if linux_audit_rules_kernel_modules | bool %}
-a always,exit -F arch=b64 -S init_module,finit_module,delete_module -k modules
{% endif %}

## ──────────────────────────────────────────────
##  ptrace / debugging attempts
## ──────────────────────────────────────────────
{% if linux_audit_rules_ptrace | bool %}
-a always,exit -F arch=b64 -S ptrace -k ptrace
{% endif %}

## ──────────────────────────────────────────────
##  Time change attempts (anti-forensic)
## ──────────────────────────────────────────────
{% if linux_audit_rules_time | bool %}
-a always,exit -F arch=b64 -S adjtimex,settimeofday,stime -k time-change
-a always,exit -F arch=b64 -S clock_settime -k time-change
{% endif %}

## ──────────────────────────────────────────────
##  Very broad / high-volume rules (disabled by default)
## ──────────────────────────────────────────────
{% if linux_audit_rules_exec | bool %}
-a always,exit -F arch=b64 -S execve -k exec
{% endif %}

{% if linux_audit_rules_network | bool %}
-a always,exit -F arch=b64 -S bind,connect -k network
{% endif %}

{% if linux_audit_rules_file_integrity_high | bool %}
-w /bin/ -p wa -k bin-integrity
-w /sbin/ -p wa -k bin-integrity
-w /usr/bin/ -p wa -k bin-integrity
-w /usr/sbin/ -p wa -k bin-integrity
{% endif %}

## Make the ruleset immutable (last rule!)
-e 2
